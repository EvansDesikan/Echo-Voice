# ECHO Voice — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# === REQUIRED ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://echovoice:echovoice@localhost:5432/echovoice

# === OBJECT STORAGE ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# === VOICE MODEL ===
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda     # use "cpu" if no GPU

# === APP ===
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string

# === FRONTEND / VERCEL ===
# Set to "true" on Vercel to enable demo mode (mocks all API calls, no backend needed)
# VITE_DEMO_MODE=true
